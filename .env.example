# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID — get it from @userinfobot
# Leave blank to allow anyone (not recommended)
ALLOWED_TELEGRAM_USER_ID=your_telegram_user_id_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# From running setup.py
AGENT_ID=your_agent_id_here
ENVIRONMENT_ID=your_environment_id_here

# Your vault GitHub repo (private)
# e.g. https://YOUR_USERNAME:YOUR_PAT@github.com/YOUR_USERNAME/obsidian-vault.git
VAULT_GITHUB_REPO=

GROQ_API_KEY=your_groq_api_key_here

# Railway: set to /data/sessions.db after adding a Volume mounted at /data
# Leave blank for local dev (defaults to sessions.db in current dir)
DB_PATH=
